# ============================================================
# TaskClaw Frontend — Environment Variables
# ============================================================
# Copy to .env and fill in:  cp .env.example .env
# ============================================================

# --- Edition ---
# "community" for self-hosted, "cloud" for managed TaskClaw Cloud
NEXT_PUBLIC_EDITION=community

# --- Backend API URL ---
# In Docker this is auto-configured (http://backend:3003). For local dev use localhost.
NEXT_PUBLIC_API_URL=http://localhost:3003

# --- URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# --- Cookies ---
# The auth session cookie is marked `Secure` in production (HTTPS). Browsers DROP
# Secure cookies over plain HTTP, breaking login on remote http://<ip> self-hosted
# deploys (localhost is exempt). Uncomment to serve over plain HTTP.
# COOKIE_SECURE=false

# --- Branding ---
NEXT_PUBLIC_BRAND_NAME="TaskClaw"

# --- Theme ---
# Valid values: commercial | corporate | funky | blue | red
APP_THEME_NAME=commercial
