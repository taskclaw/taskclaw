# ============================================================
# TaskClaw Frontend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Edition ---
# "community" for self-hosted, "cloud" for managed TaskClaw Cloud
NEXT_PUBLIC_EDITION=community

# --- Supabase (auth only — BFF pattern) ---
# Must match the Supabase instance your backend uses.
# If using `docker compose --profile supabase`, use:
#   NEXT_PUBLIC_SUPABASE_URL=http://localhost:7431
# If using Supabase Cloud, use your project URL:
#   NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://localhost:7431
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Backend API URL ---
# In Docker, this is auto-configured. For local dev, use localhost.
NEXT_PUBLIC_API_URL=http://localhost:3003

# --- URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# --- Branding ---
NEXT_PUBLIC_BRAND_NAME="TaskClaw"

# --- Theme ---
# Valid values: commercial | corporate | funky | blue | red
APP_THEME_NAME=commercial
