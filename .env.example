# ============================================================
# TaskClaw — Docker Compose Environment Variables
# ============================================================
# Copy this file to .env and customize if needed:
#   cp .env.example .env
#
# These variables configure the Docker Compose services.
# For backend/frontend specific vars, see their own .env files.
# ============================================================

# --- Version ---
# Pin to a specific release (e.g., v1.0.0) or use "latest"
TASKCLAW_VERSION=latest

# --- Supabase Local (only used with --profile supabase) ---
POSTGRES_PASSWORD=postgres
JWT_SECRET=change-me-generate-a-secret-at-least-32-chars-long

# Supabase API keys — must be signed with the JWT_SECRET above.
# Generate at: https://supabase.com/docs/guides/self-hosting#api-keys
ANON_KEY=your-supabase-anon-key
SERVICE_ROLE_KEY=your-supabase-service-role-key

# Domain for Supabase services
DOMAIN=localhost

# --- Realtime (only used with --profile supabase) ---
# Phoenix SECRET_KEY_BASE for the realtime service. A working default is baked
# into docker-compose.yml; override it in production:  openssl rand -base64 48
# REALTIME_SECRET_KEY_BASE=
