# ============================================================
# TaskClaw — Docker Compose Environment Variables
# ============================================================
# Copy to .env and customize:  cp .env.example .env
# Configures the docker-compose services (plain Postgres stack).
# ============================================================

# --- Version ---
# Pin to a specific release (e.g., v1.0.0) or use "latest"
TASKCLAW_VERSION=latest

# --- Postgres ---
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# --- Auth / JWT ---
# Shared secret used to sign access tokens. Generate: openssl rand -hex 32
JWT_SECRET=change-me-generate-a-secret-at-least-32-chars-long

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# Public base URL the browser uses to fetch uploaded files (knowledge/skill attachments).
# Local dev = the host-published MinIO port; behind a proxy use that URL.
S3_PUBLIC_URL=http://localhost:9000

# --- Ports ---
BACKEND_PORT=3003
FRONTEND_PORT=3002
