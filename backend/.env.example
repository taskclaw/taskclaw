# ============================================================
# TaskClaw Backend — Environment Variables
# ============================================================
# Copy to .env and fill in:  cp .env.example .env
# ============================================================

# --- Server ---
PORT=3003

# --- Edition ---
# "community" for self-hosted, "cloud" for managed TaskClaw Cloud
EDITION=community

# --- Database (plain PostgreSQL) ---
# In docker-compose this is overridden to reach the `db` service.
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres
# Connection pool size (tune against Postgres max_connections).
DB_POOL_MAX=10

# --- Auth & Security ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-a-random-32-char-string
ENCRYPTION_KEY=change-me-generate-a-random-64-hex-string
# Local Postgres auth (bcrypt + locally-signed JWTs). Always true post-migration.
AUTH_LOCAL=true
# Base URL used in password-reset email links (SITE_URL/update-password?token=...)
SITE_URL=http://localhost:3002

# --- Object storage (MinIO / S3-compatible) ---
# In docker-compose these are overridden to reach the `minio` service.
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# --- CORS ---
CORS_ORIGIN=http://localhost:3002

# --- Redis (BullMQ job queue) ---
REDIS_URL=redis://redis:6379

# --- AI Provider ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini

# ============================================================
# Cloud-only (EDITION=cloud) — Not needed for self-hosted
# ============================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
