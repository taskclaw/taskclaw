# ============================================================
# TaskClaw Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Server ---
PORT=3003

# --- Edition ---
# "community" for self-hosted, "cloud" for managed TaskClaw Cloud
EDITION=community

# --- Supabase ---
# Point to your Supabase instance (cloud or local).
# If using `docker compose --profile supabase`, use:
#   SUPABASE_URL=http://kong:8000
# If using Supabase Cloud, use your project URL:
#   SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=http://kong:8000
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Auth & Security ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-a-random-32-char-string
ENCRYPTION_KEY=change-me-generate-a-random-64-hex-string

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3002

# --- Redis ---
# Used for BullMQ job queue. Auto-configured in Docker.
REDIS_URL=redis://redis:6379

# --- AI Provider ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini

# ============================================================
# Cloud-only (EDITION=cloud) — Not needed for self-hosted
# ============================================================

# --- Stripe (billing) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Langfuse (AI observability) ---
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
